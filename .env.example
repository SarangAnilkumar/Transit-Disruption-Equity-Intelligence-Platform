GTFS_STATIC_URL=https://opendata.transport.vic.gov.au/dataset/3f4e292e-7f8a-4ffe-831f-1953be0fe448/resource/fb152201-859f-4882-9206-b768060b50ad/download/gtfs.zip
GTFS_REALTIME_TRIP_UPDATES_URL=https://api.opendata.transport.vic.gov.au/opendata/public-transport/gtfs/realtime/v1/metro/trip-updates
GTFS_REALTIME_SERVICE_ALERTS_URL=https://api.opendata.transport.vic.gov.au/opendata/public-transport/gtfs/realtime/v1/metro/service-alerts
TRANSPORT_API_KEY=
TRANSPORT_API_AUTH_MODE=header
TRANSPORT_API_HEADER_NAME=Ocp-Apim-Subscription-Key
TRANSPORT_API_QUERY_PARAM_NAME=subscription-key
# If Ocp-Apim-Subscription-Key fails, try TRANSPORT_API_HEADER_NAME=KeyID
# If header auth fails, try TRANSPORT_API_AUTH_MODE=query with subscription-key
# Never commit real API keys.
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SA2_BOUNDARIES_PATH=data/raw/geospatial/sa2_boundaries/<your_sa2_boundary_file.gpkg>
# Optional: required only when SA2_BOUNDARIES_PATH points to a multi-layer GeoPackage
SA2_BOUNDARY_LAYER=
SEIFA_SA2_PATH=data/raw/equity/seifa/<your_seifa_sa2_file.xlsx>
# Raw ABS/SEIFA source files should not be committed.
# Use ABS ASGS Edition 3 / 2021 SA2 digital boundaries where possible.
# Use 2021 SA2-level SEIFA where possible.
